# VibeTrading Environment Variables
# Copy this file to .env.local and fill in your values.

# Z.AI API credentials (used by the agent / backtest / shadow-account routes).
# In production on Vercel, set these in Project Settings → Environment Variables.
# Get yours from https://z.ai
ZAI_API_KEY=your_zai_api_key_here
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
